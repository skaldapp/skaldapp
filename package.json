{
  "$schema": "https://www.schemastore.org/package",
  "name": "skaldapp",
  "version": "4.3.1",
  "description": "Skald is an open-source browser-based Vue.js web editor that allows creating static websites with Vue SFCs without Node.js setup. Features runtime SFC compilation, Monaco editor, WYSIWYG mode, Tailwind CSS, and multiple storage options.",
  "keywords": [
    "vuejs",
    "web-editor",
    "browser-based",
    "open-source",
    "sfc",
    "single-file-components",
    "runtime-compilation",
    "monaco-editor",
    "wysiwyg",
    "tailwind-css",
    "unocss",
    "quasar",
    "typescript",
    "vite",
    "static-websites",
    "no-setup",
    "development-environment",
    "electron",
    "cross-platform",
    "i18n"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skaldapp/skaldapp.git"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Jerry Bruwes <jbruwes@gmail.com>",
  "type": "module",
  "scripts": {
    "build": "quasar build",
    "build:electron": "quasar build -m electron",
    "dev": "quasar dev",
    "dev:electron": "quasar dev -m electron",
    "postinstall": "quasar prepare",
    "lint": "eslint ."
  },
  "prettier": "@skaldapp/configs/prettierrc",
  "dependencies": {
    "@ai-sdk/mistral": "^3.0.35",
    "@ai-sdk/vue": "^3.0.175",
    "@aws-sdk/client-s3": "^3.1044.0",
    "@electron/remote": "^2.1.3",
    "@iconify/vue": "^5.0.1",
    "@milkdown/crepe": "^7.20.0",
    "@milkdown/ctx": "^7.20.0",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/plugin-emoji": "^7.20.0",
    "@milkdown/utils": "^7.20.0",
    "@milkdown/vue": "^7.20.0",
    "@nuxtlabs/monarch-mdc": "^0.9.0",
    "@quasar/app-vite": "^2.6.0",
    "@quasar/extras": "^1.18.0",
    "@skaldapp/fsa": "^1.1.8",
    "@skaldapp/milkdown-copilot": "^0.0.19",
    "@skaldapp/monaco-sfc": "^1.1.42",
    "@skaldapp/shared": "^1.2.74",
    "@smithy/fetch-http-handler": "^5.3.17",
    "@unhead/vue": "^3.1.0",
    "@vueuse/core": "^14.3.0",
    "ai": "^6.0.175",
    "crypto-es": "^3.1.3",
    "electron-updater": "^6.8.3",
    "globals": "^17.6.0",
    "hexo-front-matter": "^5.0.0",
    "jsonrepair": "^3.14.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mdast-util-to-markdown": "^2.1.2",
    "mime": "^4.1.0",
    "monaco-editor": "0.52.2",
    "monaco-tailwind": "^0.1.0-alpha.2",
    "monacopilot": "^1.2.12",
    "path-browserify": "^1.0.1",
    "pinia": "^3.0.4",
    "pinia-plugin-store": "^3.0.9",
    "prismjs": "^1.30.0",
    "quasar": "^2.19.3",
    "unhead": "^3.1.0",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@fontsource/noto-sans": "^5.2.10",
    "@fontsource/noto-serif": "^5.2.9",
    "@fontsource/space-mono": "^5.2.9",
    "@intlify/unplugin-vue-i18n": "^11.1.2",
    "@quasar/quasar-app-extension-qmarkdown": "^2.0.5",
    "@skaldapp/configs": "^1.2.105",
    "@skaldapp/runtime": "^3.3.12",
    "@types/markdown-it-emoji": "^3.0.1",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/path-browserify": "^1.0.3",
    "@types/prismjs": "^1.26.6",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@unocss/vite": "^66.6.8",
    "autoprefixer": "^10.5.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "nord": "^0.2.1",
    "vite": "^8.0.11",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-static-copy": "^4.1.0"
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {
        "overrideBrowserslist": [
          "last 4 Chrome versions",
          "last 4 Firefox versions",
          "last 4 Edge versions",
          "last 4 Safari versions",
          "last 4 Android versions",
          "last 4 ChromeAndroid versions",
          "last 4 FirefoxAndroid versions",
          "last 4 iOS versions"
        ]
      }
    }
  },
  "productName": "Skald"
}
